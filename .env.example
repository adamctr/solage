# Mode d'exécution : development (assets non minifiés, HTTP) ou production
# (assets minifiés, cookie Secure). Surchargé par les fichiers docker-compose.
APP_ENV=development

# Database (PostgreSQL)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=solage
DB_USER=solage
DB_PASSWORD=change-me

# Production only (docker-compose.prod.yml)
APP_DOMAIN=solage.example.com
ACME_EMAIL=ops@example.com
